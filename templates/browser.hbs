<div class="lal-root">
  {{#if isScanning}}
    <div class="lal-empty">
      <p><i class="fas fa-spinner fa-spin"></i> 正在扫描素材库...</p>
      <p style="opacity:0.6;font-size:0.85em">首次扫描约 30 秒,之后从缓存秒载</p>
    </div>
  {{else}}
    <header class="lal-header">
      <input class="lal-search" type="text" placeholder="搜文件名/合集/scene 名..." value="{{searchQuery}}" />
      <select class="lal-filter-type" title="资产类型">
        <option value="">全部类型</option>
        {{#each types}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}} ({{count}})</option>{{/each}}
      </select>
      <select class="lal-filter-creator" title="创作者">
        <option value="">全部创作者</option>
        {{#each creators}}<option value="{{name}}" {{#if selected}}selected{{/if}}>{{name}} ({{count}})</option>{{/each}}
      </select>
      <select class="lal-filter-sort" title="排序">
        {{#each sortOptions}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
      </select>
      <button type="button" class="lal-toggle-favorites" title="只看收藏 ({{favoritesCount}} 个)" {{#if favoritesOnly}}data-active="1"{{/if}}>
        <i class="fas fa-star"></i>
      </button>
      <button type="button" class="lal-toggle-select" title="多选" {{#if selectMode}}data-active="1"{{/if}}>
        <i class="fas fa-check-square"></i>
      </button>
      <button type="button" class="lal-scan" title="重扫(无视缓存)"><i class="fas fa-sync"></i></button>
    </header>

    {{#if filterCreator}}
    <div class="lal-subfilter">
      <select class="lal-filter-pack" title="合集">
        <option value="">{{filterCreator}} 全部合集</option>
        {{#each packs}}<option value="{{name}}" {{#if selected}}selected{{/if}}>{{name}} ({{count}})</option>{{/each}}
      </select>
      {{#if subFolders.length}}
      <select class="lal-filter-folder" title="子文件夹">
        <option value="">全部子文件夹</option>
        {{#each subFolders}}<option value="{{name}}" {{#if selected}}selected{{/if}}>{{name}}/</option>{{/each}}
      </select>
      {{/if}}
    </div>
    {{/if}}

    <div class="lal-stats">
      <span>{{total}} 个匹配 · 显示 {{pageStart}}-{{pageEnd}}{{#if favoritesOnly}} · 收藏模式{{/if}}</span>
      {{#if selectMode}}
        <span class="lal-select-bar">
          已选 <span class="lal-selected-count">{{selectedCount}}</span> ·
          <button type="button" class="lal-bulk-import"><i class="fas fa-file-import"></i> 批量导入选中</button>
          <button type="button" class="lal-clear-select">清空</button>
        </span>
      {{/if}}
    </div>

    {{#unless assets.length}}
      <div class="lal-empty-results">
        <p><i class="fas fa-search"></i> 没有匹配的素材</p>
        <p style="opacity:0.6;font-size:0.85em">试试改一下搜索词或筛选条件</p>
      </div>
    {{/unless}}

    <div class="lal-grid">
      {{#each assets}}
        <div class="lal-tile {{#if isSelected}}lal-tile-selected{{/if}} {{#if isFavorite}}lal-tile-fav{{/if}}"
             draggable="{{#unless ../selectMode}}true{{else}}false{{/unless}}"
             data-url="{{url}}" data-id="{{id}}"
             data-type="{{typeId}}" data-w="{{imgW}}" data-h="{{imgH}}"
             data-pack-path="{{packPath}}" data-name="{{baseName}}"
             title="{{filepath}}&#10;{{pack}} · {{creator}}&#10;{{sizeText}} · {{filesizeKb}}KB">
          {{#if ../selectMode}}
            <label class="lal-tile-check-wrap">
              <input type="checkbox" class="lal-tile-checkbox" data-id="{{id}}" {{#if isSelected}}checked{{/if}} />
            </label>
          {{/if}}
          <div class="lal-thumb" style="background-color: {{mainColor}};">
            {{#if thumbUrl}}<img src="{{thumbUrl}}" loading="lazy" draggable="false" onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';" /><span class="lal-type-badge" style="display:none">{{typeName}}</span>
            {{else if isImage}}<img src="{{url}}" loading="lazy" draggable="false" />
            {{else}}<span class="lal-type-badge">{{typeName}}</span>{{/if}}
            {{#if isAnimated}}<span class="lal-anim-badge" title="动图/视频"><i class="fas fa-play-circle"></i></span>{{/if}}
            {{#if healthClass}}<span class="lal-health-badge lal-health-{{healthClass}}" title="{{#unless healthMissing}}所有 {{healthTotal}} 个 tile 都在本地{{else}}缺 {{healthMissing}}/{{healthTotal}} 个 tile{{/unless}}"><i class="fas fa-{{healthIcon}}"></i></span>{{/if}}
            {{#unless ../selectMode}}
              <div class="lal-overlay">
                <div class="lal-menu">
                  <button type="button" class="lal-action-import" title="导入到 Foundry"><i class="fas fa-file-import"></i></button>
                  <button type="button" class="lal-action-preview" title="预览"><i class="fas fa-eye"></i></button>
                  <button type="button" class="lal-action-favorite" title="{{#if isFavorite}}取消收藏{{else}}收藏{{/if}}"><i class="fas {{#if isFavorite}}fa-star{{else}}fa-star-o far fa-star{{/if}}"></i></button>
                  <button type="button" class="lal-action-clipboard" title="复制本地路径"><i class="fas fa-copy"></i></button>
                </div>
              </div>
            {{/unless}}
          </div>
          <div class="lal-name">{{baseName}}</div>
          <div class="lal-meta">{{#if isScenePacker}}{{spMeta}}{{else}}{{pack}}{{/if}}</div>
        </div>
      {{/each}}
    </div>

    <footer class="lal-footer">
      <button type="button" class="lal-page-prev">← 上页</button>
      <span class="lal-page-info">第 {{page}} / {{totalPages}} 页</span>
      <button type="button" class="lal-page-next">下页 →</button>
    </footer>
  {{/if}}
</div>
